<div class="container">
  <h1 class="mb-4">My Orders</h1>

  <% if @orders.any? %>
    <table class="table">
      <thead>
        <tr>
          <th>Order ID</th>
          <th>Status</th>
          <th>Items</th>
          <th>GST</th>
          <th>PST</th>
          <th>HST</th>
          <th>Total</th>
          <th>Placed On</th>
          <th>Details</th>
        </tr>
      </thead>
      <tbody>
        <% @orders.each do |order| %>
          <tr>
            <td><%= order.id %></td>
            <td><%= order.status %></td>
            <td><%= order.order_items.sum(:quantity) %></td>
            <td>$<%= order.gst_amount %></td>
            <td>$<%= order.pst_amount %></td>
            <td>$<%= order.hst_amount %></td>
            <td>$<%= order.total %></td>
            <td><%= order.created_at.strftime("%Y-%m-%d %H:%M") %></td>
            <td><%= link_to "View", order_path(order), class: "btn btn-sm btn-primary" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p>You have not placed any orders yet.</p>
  <% end %>
</div>