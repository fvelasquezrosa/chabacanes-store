<div class="container">
  <h1 class="mb-4">
    <%= @category.present? ? "#{@category.name} Products" : "Shop All Products" %>
  </h1>

  <div class="row">
    <% @products.each do |product| %>
      <%= render "products/product_card", product: product %>
    <% end %>
  </div>

  <div class="mt-4">
    <%= paginate @products %>
  </div>
</div>