<div class="col-md-4 mb-4">
  <div class="card h-100">
    <% if product.image.attached? %>
      <%= image_tag product.image.variant(resize_to_fill: [400, 300]), class: "card-img-top", style: "height: 250px; object-fit: cover;" %>
    <% else %>
      <div class="border-bottom text-center p-5">No image</div>
    <% end %>

    <div class="card-body">
      <h5 class="card-title"><%= product.title %></h5>
      <p class="card-text"><strong>Category:</strong> <%= product.category.name %></p>
      <p class="card-text"><strong>Price:</strong> $<%= product.price %></p>
      <p class="card-text"><%= truncate(product.description, length: 90) %></p>
      <%= link_to "View Product", product_path(product), class: "btn btn-primary" %>
    </div>
  </div>
</div>