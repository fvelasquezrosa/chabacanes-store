<div class="container mb-3">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><%= link_to "Home", root_path %></li>
      <li class="breadcrumb-item">
        <%= link_to @product.category.name, category_path(@product.category) %>
      </li>
      <li class="breadcrumb-item active" aria-current="page"><%= @product.title %></li>
    </ol>
  </nav>
</div>

<div class="container">
  <div class="row">
    <div class="col-md-6">
      <% if @product.image.attached? %>
        <%= image_tag @product.large_image, class: "img-fluid rounded" %>
      <% else %>
        <div class="border rounded p-5 text-center">No image uploaded</div>
      <% end %>
    </div>

    <div class="col-md-6">
      <h1><%= @product.title %></h1>
      <p><strong>Category:</strong> <%= @product.category.name %></p>
      <p><strong>Price:</strong> $<%= @product.price %></p>
      <p><strong>Stock:</strong> <%= @product.stock_quantity %></p>
      <p><%= @product.description %></p>

      <%= button_to "Add to Cart", add_to_cart_path(@product), method: :post, class: "btn btn-success" %>
      <%= link_to "Back to Products", root_path, class: "btn btn-secondary ms-2" %>
    </div>
  </div>
</div>