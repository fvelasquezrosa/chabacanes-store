<div class="container">
  <h1 class="mb-4">Shopping Cart</h1>

  <% if @cart_items.any? %>
    <table class="table">
      <thead>
        <tr>
          <th>Product</th>
          <th>Price</th>
          <th>Quantity</th>
          <th>Update Quantity</th>
          <th>Remove</th>
          <th>Line Total</th>
        </tr>
      </thead>
      <tbody>
        <% grand_total = 0 %>

        <% @cart_items.each do |item| %>
          <% line_total = item[:product].price * item[:quantity] %>
          <% grand_total += line_total %>

          <tr>
            <td><%= item[:product].title %></td>
            <td>$<%= item[:product].price %></td>
            <td><%= item[:quantity] %></td>
            <td>
              <%= form_with url: update_cart_path(item[:product]), method: :patch, local: true do %>
                <div class="d-flex gap-2">
                  <%= number_field_tag :quantity, item[:quantity], min: 0, class: "form-control", style: "width: 90px;" %>
                  <%= submit_tag "Update", class: "btn btn-warning btn-sm" %>
                </div>
              <% end %>
            </td>
            <td>
              <%= button_to "Remove", remove_from_cart_path(item[:product]), method: :delete, class: "btn btn-danger btn-sm" %>
            </td>
            <td>$<%= line_total %></td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <h4>Grand Total: $<%= grand_total %></h4>
  <% else %>
    <p>Your cart is empty.</p>
  <% end %>

  <%= link_to "Continue Shopping", root_path, class: "btn btn-primary" %>
</div>